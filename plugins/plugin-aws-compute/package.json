    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@terrastudio/core": "workspace:*",
    "@terrastudio/types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@vitest/coverage-v8": "^4.0.18",
    "vitest": "^4.0.18"
  }
}
