{
  "name": "@terrastudio/plugin-aws-compute",
  "version": "0.1.0",
  "description": "AWS compute resources plugin (Security Group, EC2, EIP, ALB, RDS) for TerraStudio",
  "author": "afroze9 <afrozeamjad@gmail.com>",
  "license": "AGPL-3.0-only",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "svelte": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
